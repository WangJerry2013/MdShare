<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <%- include('../includes/favicon') %>
    <base href="<%- serverURL %>/">
    <title><%= __('Users') %> - <%= __('Admin Console') %> - MdShare</title>
    <%- include('../build/index-pack-header') %>
    <style>
        .admin-container { padding: 80px 20px 20px; max-width: 1200px; margin: 0 auto; }
        .badge { display: inline-block; padding: 2px 8px; border-radius: 10px; font-size: 11px; font-weight: 600; }
        .badge-admin { background: #5cb85c; color: #fff; }
        .badge-user { background: #eee; color: #666; }
        .batch-actions { margin-bottom: 12px; }
        .batch-actions .btn { margin-right: 6px; }
    </style>
    <script>
        function toggleAll(src) {
            var checkboxes = document.getElementsByName('selectedIds');
            for (var i = 0; i < checkboxes.length; i++) {
                checkboxes[i].checked = src.checked;
            }
        }
        function confirmBatchDelete(prefix) {
            var checked = document.querySelectorAll('input[name="selectedIds"]:checked');
            if (checked.length === 0) {
                alert('<%= __('Please select at least one item.') %>');
                return false;
            }
            return confirm('<%= __('Are you sure you want to delete the selected items?') %>');
        }
    </script>
</head>

<body>
    <nav class="navbar navbar-default navbar-fixed-top">
        <div class="container-fluid">
            <div class="navbar-header">
                <a class="navbar-brand" href="<%- serverURL %>/admin" style="font-weight:600;">MdShare <small style="font-size:12px;color:#999;"><%= __('Admin Console') %></small></a>
            </div>
            <ul class="nav navbar-nav">
                <li><a href="<%- serverURL %>/admin"><i class="fa fa-dashboard"></i> <%= __('Dashboard') %></a></li>
                <li class="active"><a href="<%- serverURL %>/admin/users"><i class="fa fa-users"></i> <%= __('Users') %></a></li>
                <li><a href="<%- serverURL %>/admin/notes"><i class="fa fa-file-text"></i> <%= __('Notes') %></a></li>
            </ul>
            <ul class="nav navbar-nav navbar-right">
                <li><a href="<%- serverURL %>/"><i class="fa fa-arrow-left"></i> <%= __('Back to MdShare') %></a></li>
            </ul>
        </div>
    </nav>

    <div class="admin-container">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;">
            <h4 style="margin:0;"><%= __('All Users') %></h4>
            <a href="<%- serverURL %>/admin/users/create" class="btn btn-sm btn-success"><i class="fa fa-plus"></i> <%= __('Create User') %></a>
        </div>
        <form method="POST" action="<%- serverURL %>/admin/users/batch-delete" onsubmit="return confirmBatchDelete()">
            <div class="batch-actions">
                <button type="submit" class="btn btn-sm btn-danger"><i class="fa fa-trash"></i> <%= __('Delete Selected') %></button>
            </div>
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th style="width:32px;"><input type="checkbox" onchange="toggleAll(this)"></th>
                        <th><%= __('Email') %></th>
                        <th><%= __('Role') %></th>
                        <th><%= __('Notes') %></th>
                        <th><%= __('Registered') %></th>
                        <th><%= __('Last Active') %></th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    <% if (users.length === 0) { %>
                    <tr><td colspan="7" style="text-align:center;color:#999;"><%= __('No users found.') %></td></tr>
                    <% } else { %>
                    <% users.forEach(function(user) { %>
                    <tr>
                        <td><input type="checkbox" name="selectedIds" value="<%= user.id %>"></td>
                        <td><%= user.email %></td>
                        <td><span class="badge <%= user.isAdmin ? 'badge-admin' : 'badge-user' %>"><%= user.isAdmin ? __('Admin') : __('User') %></span></td>
                        <td><%= user.noteCount %></td>
                        <td><%= user.createdAt %></td>
                        <td><%= user.lastActive || __('Never') %></td>
                        <td style="white-space:nowrap;">
                            <a href="<%- serverURL %>/admin/users/<%= user.id %>" class="btn btn-sm btn-default"><%= __('View') %></a>
                            <a href="<%- serverURL %>/admin/users/<%= user.id %>/change-password" class="btn btn-sm btn-warning"><i class="fa fa-key"></i> <%= __('Change Password') %></a>
                            <a href="<%- serverURL %>/admin/users/<%= user.id %>/delete" class="btn btn-sm btn-danger" onclick="return confirm('<%= __('Are you sure you want to delete this user?') %>')"><i class="fa fa-trash"></i> <%= __('Delete') %></a>
                        </td>
                    </tr>
                    <% }) } %>
                </tbody>
            </table>
        </form>
    </div>
</body>
</html>
