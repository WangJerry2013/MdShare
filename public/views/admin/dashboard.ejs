<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <%- include('../includes/favicon') %>
    <base href="<%- serverURL %>/">
    <title><%= __('Dashboard') %> - <%= __('Admin Console') %> - MdShare</title>
    <%- include('../build/index-pack-header') %>
    <style>
        .admin-container { padding: 80px 20px 20px; max-width: 1200px; margin: 0 auto; }
        .stat-card { background: #fff; border: 1px solid #ddd; border-radius: 6px; padding: 24px; margin-bottom: 20px; text-align: center; box-shadow: 0 1px 3px rgba(0,0,0,.08); }
        .stat-card h3 { margin: 0 0 8px; font-size: 32px; color: #333; }
        .stat-card p { margin: 0; color: #777; font-size: 13px; }
        .admin-nav { margin-bottom: 24px; }
        .admin-nav a { margin-right: 12px; }
        .table-note-list { width: 100%; }
        .table-note-list th, .table-note-list td { padding: 8px 12px; text-align: left; border-bottom: 1px solid #eee; }
        .badge { display: inline-block; padding: 2px 8px; border-radius: 10px; font-size: 11px; font-weight: 600; }
        .badge-admin { background: #5cb85c; color: #fff; }
        .badge-user { background: #eee; color: #666; }
    </style>
</head>

<body>
    <nav class="navbar navbar-default navbar-fixed-top">
        <div class="container-fluid">
            <div class="navbar-header">
                <a class="navbar-brand" href="<%- serverURL %>/admin" style="font-weight:600;">MdShare <small style="font-size:12px;color:#999;"><%= __('Admin Console') %></small></a>
            </div>
            <ul class="nav navbar-nav">
                <li class="active"><a href="<%- serverURL %>/admin"><i class="fa fa-dashboard"></i> <%= __('Dashboard') %></a></li>
                <li><a href="<%- serverURL %>/admin/users"><i class="fa fa-users"></i> <%= __('Users') %></a></li>
                <li><a href="<%- serverURL %>/admin/notes"><i class="fa fa-file-text"></i> <%= __('Notes') %></a></li>
            </ul>
            <ul class="nav navbar-nav navbar-right">
                <li><a href="<%- serverURL %>/"><i class="fa fa-arrow-left"></i> <%= __('Back to MdShare') %></a></li>
            </ul>
        </div>
    </nav>

    <div class="admin-container">
        <% if (typeof needsPasswordChange !== 'undefined' && needsPasswordChange) { %>
        <div class="alert alert-warning" style="margin-bottom: 16px;">
            <i class="fa fa-exclamation-triangle"></i>
            <%= __('You are using the default password. Please reset it for security.') %>
            <a href="<%- serverURL %>/admin/users/<%= currentUserId %>/change-password" class="btn btn-sm btn-warning" style="margin-left:12px;">
                <i class="fa fa-key"></i> <%= __('Change Password') %>
            </a>
        </div>
        <% } %>
        <div class="row">
            <div class="col-sm-4">
                <div class="stat-card">
                    <h3><%= totalUsers %></h3>
                    <p><%= __('Registered Users') %></p>
                </div>
            </div>
            <div class="col-sm-4">
                <div class="stat-card">
                    <h3><%= totalNotes %></h3>
                    <p><%= __('Total Notes') %></p>
                </div>
            </div>
            <div class="col-sm-4">
                <div class="stat-card">
                    <h3><%= totalRevisions %></h3>
                    <p><%= __('Total Revisions') %></p>
                </div>
            </div>
        </div>

        <h4 style="margin-top: 32px; margin-bottom: 16px;"><%= __('Recent Activity') %></h4>
        <table class="table table-striped">
            <thead>
                <tr>
                    <th><%= __('Note') %></th>
                    <th><%= __('Owner') %></th>
                    <th><%= __('Last Editor') %></th>
                    <th><%= __('Last Updated') %></th>
                </tr>
            </thead>
            <tbody>
                <% if (recentNotes.length === 0) { %>
                <tr><td colspan="4" style="text-align:center;color:#999;"><%= __('No notes yet.') %></td></tr>
                <% } else { %>
                <% recentNotes.forEach(function(note) { %>
                <tr>
                    <td><a href="<%- serverURL %>/<%= note.shortid || note.id %>" target="_blank" rel="noopener"><%= note.title || __('(untitled)') %></a></td>
                    <td><%= note.owner ? note.owner.email : __('(anonymous)') %></td>
                    <td><%= note.lastchangeuser ? note.lastchangeuser.email : __('(anonymous)') %></td>
                    <td><%= note.updatedAt %></td>
                </tr>
                <% }) } %>
            </tbody>
        </table>
    </div>
</body>
</html>
