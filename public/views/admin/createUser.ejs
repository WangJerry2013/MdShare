<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <%- include('../includes/favicon') %>
    <base href="<%- serverURL %>/">
    <title><%= __('Create User') %> - <%= __('Admin Console') %> - MdShare</title>
    <%- include('../build/index-pack-header') %>
    <style>
        .admin-container { padding: 80px 20px 20px; max-width: 1200px; margin: 0 auto; }
        .form-box { max-width: 480px; padding: 24px; background: #f9f9f9; border: 1px solid #eee; border-radius: 6px; }
    </style>
</head>

<body>
    <nav class="navbar navbar-default navbar-fixed-top">
        <div class="container-fluid">
            <div class="navbar-header">
                <a class="navbar-brand" href="<%- serverURL %>/admin" style="font-weight:600;">MdShare <small style="font-size:12px;color:#999;"><%= __('Admin Console') %></small></a>
            </div>
            <ul class="nav navbar-nav">
                <li><a href="<%- serverURL %>/admin"><i class="fa fa-dashboard"></i> <%= __('Dashboard') %></a></li>
                <li class="active"><a href="<%- serverURL %>/admin/users"><i class="fa fa-users"></i> <%= __('Users') %></a></li>
                <li><a href="<%- serverURL %>/admin/notes"><i class="fa fa-file-text"></i> <%= __('Notes') %></a></li>
            </ul>
            <ul class="nav navbar-nav navbar-right">
                <li><a href="<%- serverURL %>/"><i class="fa fa-arrow-left"></i> <%= __('Back to MdShare') %></a></li>
            </ul>
        </div>
    </nav>

    <div class="admin-container">
        <a href="<%- serverURL %>/admin/users">&larr; <%= __('Back to Users') %></a>

        <h4 style="margin-top: 16px; margin-bottom: 16px;"><%= __('Create User') %></h4>

        <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-danger"><%= error %></div>
        <% } %>
        <% if (typeof success !== 'undefined' && success) { %>
        <div class="alert alert-success"><%= success %></div>
        <% } %>

        <div class="form-box">
            <form method="POST" action="<%- serverURL %>/admin/users/create">
                <div class="form-group">
                    <label for="email"><%= __('Email') %></label>
                    <input type="email" name="email" id="email" class="form-control" required placeholder="user@example.com">
                </div>
                <div class="form-group">
                    <label for="password"><%= __('Password') %></label>
                    <input type="password" name="password" id="password" class="form-control" required minlength="6">
                </div>
                <div class="checkbox">
                    <label>
                        <input type="checkbox" name="isAdmin" value="true"> <%= __('Admin') %>
                    </label>
                </div>
                <button type="submit" class="btn btn-primary"><i class="fa fa-plus"></i> <%= __('Create') %></button>
            </form>
        </div>
    </div>
</body>
</html>
