<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <%- include('../includes/favicon') %>
    <base href="<%- serverURL %>/">
    <title><%= user.email %> - <%= __('User') %> - <%= __('Admin Console') %> - MdShare</title>
    <%- include('../build/index-pack-header') %>
    <style>
        .admin-container { padding: 80px 20px 20px; max-width: 1200px; margin: 0 auto; }
        .badge { display: inline-block; padding: 2px 8px; border-radius: 10px; font-size: 11px; font-weight: 600; }
        .badge-admin { background: #5cb85c; color: #fff; }
        .badge-user { background: #eee; color: #666; }
    </style>
</head>

<body>
    <nav class="navbar navbar-default navbar-fixed-top">
        <div class="container-fluid">
            <div class="navbar-header">
                <a class="navbar-brand" href="<%- serverURL %>/admin" style="font-weight:600;">MdShare <small style="font-size:12px;color:#999;"><%= __('Admin Console') %></small></a>
            </div>
            <ul class="nav navbar-nav">
                <li><a href="<%- serverURL %>/admin"><i class="fa fa-dashboard"></i> <%= __('Dashboard') %></a></li>
                <li><a href="<%- serverURL %>/admin/users"><i class="fa fa-users"></i> <%= __('Users') %></a></li>
                <li><a href="<%- serverURL %>/admin/notes"><i class="fa fa-file-text"></i> <%= __('Notes') %></a></li>
            </ul>
            <ul class="nav navbar-nav navbar-right">
                <li><a href="<%- serverURL %>/"><i class="fa fa-arrow-left"></i> <%= __('Back to MdShare') %></a></li>
            </ul>
        </div>
    </nav>

    <div class="admin-container">
        <a href="<%- serverURL %>/admin/users">&larr; <%= __('Back to Users') %></a>

        <div style="margin-top: 16px; padding: 20px; background: #f9f9f9; border: 1px solid #eee; border-radius: 6px;">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;">
                <div>
                    <h4 style="margin: 0 0 8px;"><%= user.email %></h4>
            <p style="margin: 0; color: #666;">
                <%= __('Role') %>: <span class="badge <%= user.isAdmin ? 'badge-admin' : 'badge-user' %>"><%= user.isAdmin ? __('Admin') : __('User') %></span>
                &middot; <%= __('Registered') %>: <%= user.createdAt %>
                &middot; <%= __('User ID') %>: <code><%= user.id %></code>
            </div>
                </div>
                <div style="display:flex;gap:8px;flex-shrink:0;">
                    <a href="<%- serverURL %>/admin/users/<%= user.id %>/change-password" class="btn btn-sm btn-warning"><i class="fa fa-key"></i> <%= __('Change Password') %></a>
                    <form method="POST" action="<%- serverURL %>/admin/users/<%= user.id %>/delete" onsubmit="return confirm('<%= __('Are you sure you want to delete this user?') %>')">
                        <button type="submit" class="btn btn-sm btn-danger"><i class="fa fa-trash"></i> <%= __('Delete User') %></button>
                    </form>
                </div>
            </div>
        </div>

        <h4 style="margin-top: 24px; margin-bottom: 16px;"><%= __('Notes') %> (<%= notes.length %>)</h4>
        <table class="table table-striped">
            <thead>
                <tr>
                    <th><%= __('Title') %></th>
                    <th><%= __('Alias') %></th>
                    <th><%= __('Permission') %></th>
                    <th><%= __('Views') %></th>
                    <th><%= __('Revisions') %></th>
                    <th><%= __('Created') %></th>
                    <th><%= __('Last Edit') %></th>
                    <th><%= __('Last Editor') %></th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                <% if (notes.length === 0) { %>
                <tr><td colspan="9" style="text-align:center;color:#999;"><%= __('This user has no notes.') %></td></tr>
                <% } else { %>
                <% notes.forEach(function(note) { %>
                <tr>
                    <td><a href="<%- serverURL %>/<%= note.shortid || note.id %>" target="_blank" rel="noopener"><%= note.title || __('(untitled)') %></a></td>
                    <td><%= note.alias || '-' %></td>
                    <td><%= note.permission %></td>
                    <td><%= note.viewcount %></td>
                    <td><%= note.revisionCount %></td>
                    <td><%= note.createdAt %></td>
                    <td><%= note.updatedAt %></td>
                    <td><%= note.lastEditor || __('(anonymous)') %></td>
                    <td>
                        <form method="POST" action="<%- serverURL %>/admin/notes/<%= note.id %>/delete" onsubmit="return confirm('<%= __('Are you sure you want to delete this note?') %>')">
                            <button type="submit" class="btn btn-xs btn-danger"><i class="fa fa-trash"></i> <%= __('Delete') %></button>
                        </form>
                    </td>
                </tr>
                <% }) } %>
            </tbody>
        </table>
    </div>
</body>
</html>
